{
  "compilerOptions": {
    "target": "ES2019",  // Specify ECMAScript target version
    "module": "commonjs", // Specify module code generation
    "rootDir": "src", // Specify the root directory of input files
    "outDir": "dist", // Specify the output directory for compiled files
    "strict": true, // Enable all strict type-checking options
    "esModuleInterop": true, // Enable compatibility with CommonJS modules
    "skipLibCheck": true, // Skip type checking of declaration files
    "types": ["node"], // Include Node.js type definitions
     "allowSyntheticDefaultImports": true // Allow default imports from modules with no default export
  },
  "include": ["src"] // Include all TypeScript files in the src directory
}
